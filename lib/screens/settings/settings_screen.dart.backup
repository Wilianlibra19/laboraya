                fontSize: 13.5,
                color: Colors.grey,
              ),
            ),
            const SizedBox(height: 18),
            const Text(
              'Encuentra trabajo cerca de ti.\nConecta con trabajadores locales.',
              textAlign: TextAlign.center,
